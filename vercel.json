{
  "buildCommand": "npm ci --legacy-peer-deps && npm run build",
  "outputDirectory": "dist/tawakkal-tours",
  "framework": "angular",
  "installCommand": "npm ci --legacy-peer-deps",
  "routes": [
    {
      "src": "/assets/.*",
      "dest": "$0",
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      }
    },
    {
      "src": "\\.js$",
      "dest": "$0",
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      }
    },
    {
      "src": "\\.css$",
      "dest": "$0",
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      }
    },
    {
      "src": "/(.*)",
      "destination": "/index.html",
      "status": 200
    }
  ]
}
